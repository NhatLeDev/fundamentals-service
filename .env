# Copy thành .env rồi điền (chạy local). Khi deploy Render/Railway/Cloud Run thì set trực tiếp trên dashboard, không cần file .env.

# Tăng giới hạn vnstock (đăng ký miễn phí: https://vnstocks.com/login). Không set = dùng Guest (20 req/phút).
VNSTOCK_API_KEY=vnstock_592ce82d749b63e34a0845bf0456f981

# Nguồn dữ liệu: KBS (mặc định) hoặc VCI
VNSTOCK_SOURCE=KBS

# Rate limiting: max API calls/phút. Đã có VNSTOCK_API_KEY (Community 60/phút) → để 30 cho an toàn.
# Guest tier (không key): hạ về 10.
VNSTOCK_MAX_CALLS_PER_MINUTE=30

# Cache TTLs in seconds. Fundamentals đổi theo quý → cache dài (6h) để bớt gọi upstream + sống sót cold-start.
VNINDEX_CACHE_TTL_SECONDS=300
VN30_BREADTH_CACHE_TTL_SECONDS=600
FUNDAMENTALS_CACHE_TTL_SECONDS=21600
MONEYFLOW_CACHE_TTL_SECONDS=120

# Ngân sách thời gian phía server (giây). Phải < abort 25s của frontend để luôn kịp trả lời.
FUNDAMENTALS_TOTAL_BUDGET_SECONDS=18
FUNDAMENTALS_PER_TICKER_TIMEOUT=8
FUNDAMENTALS_FETCH_WORKERS=4
MONEYFLOW_FUTURE_TIMEOUT=18

# Render/Railway tự set PORT; local có thể bỏ qua (uvicorn --port 8001)
PORT=8001
